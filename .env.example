# Copy this file to .env.local and fill in your own keys.
# Get a free Finnhub key: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here
# Get a free FRED key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# ── Members area ────────────────────────────────────────────
# Password members type to enter /members.
CLUB_PASSWORD=pick_a_shared_password
# Password that also unlocks /admin (upload/delete). Keep this private.
ADMIN_PASSWORD=pick_a_separate_admin_password
# Random secret used to sign login cookies. Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=run_openssl_rand_base64_32

# ── Dropbox file storage ────────────────────────────────────
# One-time setup (https://www.dropbox.com/developers/apps):
#   1. Create app → "Scoped access" → "App folder" → name it (e.g. hwsinvest).
#   2. Permissions tab → enable: files.content.read, files.content.write,
#      files.metadata.read. Click Submit.
#   3. Settings tab → copy "App key" and "App secret" below.
#   4. Get a refresh token (run once, replace APP_KEY):
#      a. Visit in a browser:
#         https://www.dropbox.com/oauth2/authorize?client_id=APP_KEY&token_access_type=offline&response_type=code
#         Approve, then copy the auth code shown.
#      b. Exchange it (replace CODE, APP_KEY, APP_SECRET):
#         curl https://api.dropbox.com/oauth2/token \
#           -d code=CODE -d grant_type=authorization_code \
#           -u APP_KEY:APP_SECRET
#         The JSON "refresh_token" field is DROPBOX_REFRESH_TOKEN below.
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token
# Leave blank for the app-folder root, or set a subfolder like "/Members".
DROPBOX_FOLDER=
